      ctx.fillStyle='#6f655c'; ctx.beginPath(); ctx.ellipse(x,y,rad,rad*0.72,0.2,0,7); ctx.fill();
      ctx.fillStyle='rgba(255,240,220,0.16)'; ctx.beginPath(); ctx.ellipse(x-rad*0.32,y-rad*0.32,rad*0.42,rad*0.28,0.2,0,7); ctx.fill();
      ctx.fillStyle='rgba(0,0,0,0.30)'; ctx.beginPath(); ctx.ellipse(x+rad*0.26,y+rad*0.36,rad*0.55,rad*0.3,0.2,0,7); ctx.fill();
    }
