  ctx.fillStyle=RC.grime;ctx.beginPath();ctx.ellipse((elbN.x+grip.x)/2,(elbN.y+grip.y)/2+1,2.6,1.4,0.2,0,7);ctx.fill();
  rjoint(grip.x,grip.y,3.2,RC.skin);
  rjoint(grip.x+1,grip.y-1,1.8,RC.skinHi);
  }
  // голова
  drawRiderHead(hd.x, hd.y, 9.5);
  ctx.restore();                              // конец масштаба фигуры
  ctx.lineCap='butt';ctx.lineJoin='miter';
}

function drawFrame(cx,axleY,a){
