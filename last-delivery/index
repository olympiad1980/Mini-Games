const RAMP_MIN=200, RAMP_K=1.4, RAMP_BASE=280;  // трамплин: порог отрыва; множитель (от скорости) + базовый импульс (фикс., бьёт даже на сниженной скорости)
const LEVEL_MIN=0.4, LEVEL_LOSS=3.5;          // гашение скорости при выполаживании после крутого спуска (сильнее: не «залетать» в подъём)
const SLIP_THRESH=0.22, SLIP_GAIN=50, LAUNCH_SPD=220;   // буксование: порог склона ниже, сила больше → видимая борьба в подъём
