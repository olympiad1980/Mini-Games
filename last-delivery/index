<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
<title>Last Delivery</title>
<style>
  *{margin:0;padding:0;box-sizing:border-box;}
  html,body{width:100%;height:100%;background:#0a0806;overflow:hidden;touch-action:none;
    font-family:"SFMono-Regular",ui-monospace,"Roboto Mono",monospace;color:#e8d5b0;}
  #wrap{position:relative;width:100%;height:100dvh;height:100vh;}
  canvas{display:block;width:100%;height:100%;}
  #hud{position:absolute;top:0;left:0;right:0;padding:10px 12px;
    display:flex;flex-wrap:wrap;gap:8px;align-items:center;justify-content:center;pointer-events:none;z-index:10;}
  .chip{pointer-events:auto;font-size:11px;letter-spacing:1px;
    background:rgba(15,10,5,0.72);border:1px solid rgba(251,146,60,0.28);
    color:rgba(251,146,60,0.92);padding:7px 12px;border-radius:7px;
    cursor:pointer;-webkit-tap-highlight-color:transparent;user-select:none;
    backdrop-filter:blur(6px);white-space:nowrap;transition:.12s;
    min-width:150px;text-align:center;}
  .chip:active{transform:scale(0.96);}
  .chip.on{background:rgba(251,146,60,0.18);border-color:rgba(251,146,60,0.8);color:#ffd9a0;}
  /* подложки типов рельефа */
  #btn-terr.t-plain {background:rgba(90,130,70,0.30);border-color:rgba(150,200,120,0.7);color:#d6ecc2;}
  #btn-terr.t-hills {background:rgba(200,120,50,0.30);border-color:rgba(255,170,90,0.7);color:#ffd9a0;}
  #btn-terr.t-cliffs{background:rgba(120,80,50,0.34);border-color:rgba(170,120,80,0.75);color:#e8c9a6;}
  #gas{position:absolute;right:18px;bottom:24px;z-index:10;width:100px;height:100px;border-radius:50%;
    background:rgba(25,18,10,0.6);border:2px solid rgba(255,255,255,0.9);backdrop-filter:blur(8px);
    display:flex;align-items:center;justify-content:center;font-size:13px;letter-spacing:3px;
    color:rgba(255,255,255,0.85);cursor:pointer;-webkit-tap-highlight-color:transparent;user-select:none;
    box-shadow:0 4px 22px rgba(0,0,0,0.55);transition:.07s;}
  #gas.pressed{background:rgba(251,146,60,0.25);border-color:rgba(255,210,120,1);
    box-shadow:0 0 30px rgba(251,146,60,0.55);transform:scale(0.95);}
  /* ── экран результата уровня ── */
  #result{position:absolute;inset:0;z-index:20;display:flex;flex-direction:column;
    align-items:center;justify-content:center;gap:26px;pointer-events:auto;}
  #result::before{content:"";position:absolute;inset:0;z-index:-1;
    background:rgba(8,5,3,0.42);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);
    animation:resultIn 0.55s ease both;}
  #result.hidden{display:none;}
  #result .card{width:min(86vw,360px);background:rgba(20,14,9,0.92);
    border:1px solid rgba(251,146,60,0.35);border-radius:18px;padding:26px 26px 22px;
    box-shadow:0 14px 60px rgba(0,0,0,0.65);text-align:center;
    animation:cardIn 0.5s cubic-bezier(.2,.8,.2,1) both;}
  #result .ttl{font-size:26px;letter-spacing:2px;font-weight:bold;margin-bottom:16px;}
  #result.win  .ttl{color:#7fd66a;}
  #result.lose .ttl{color:#ff6a5a;}
  #result .row{display:flex;justify-content:space-between;font-size:14px;letter-spacing:.5px;
    padding:6px 2px;color:rgba(232,213,176,0.82);border-bottom:1px solid rgba(255,255,255,0.05);}
  #result .row b{color:#fb923c;font-weight:bold;}
  #result .score{margin:16px 0 2px;font-size:15px;letter-spacing:1px;color:rgba(232,213,176,0.7);}
  #result .score b{font-size:34px;color:#ffd9a0;display:block;margin-top:2px;letter-spacing:2px;}
  /* пульсирующая кнопка по центру экрана */
  #result button{padding:17px 46px;font-size:17px;letter-spacing:2px;font-weight:bold;
    font-family:inherit;color:#1a120a;background:#fb923c;border:none;border-radius:13px;
    cursor:pointer;-webkit-tap-highlight-color:transparent;
    animation:pulseBtn 1.25s ease-in-out infinite, btnIn 0.5s ease both;}
  #result button:active{transform:scale(0.96);background:#ffb05a;animation:none;}
  @keyframes pulseBtn{
    0%,100%{transform:scale(1);}
    50%    {transform:scale(1.025);}
  }
  @keyframes resultIn{ from{opacity:0;} to{opacity:1;} }
  @keyframes btnIn{ from{opacity:0;} to{opacity:1;} }
  @keyframes cardIn{
    from{transform:translateY(12px) scale(0.96);}
    to  {transform:translateY(0) scale(1);}
  }
</style>
</head>
<body>
<div id="wrap">
  <canvas id="cv"></canvas>
  <div id="hud">
    <div class="chip t-hills" id="btn-terr" style="display:none">РЕЛЬЕФ: ХОЛМЫ</div>
    <div class="chip" id="btn-regen" style="display:none">СЛУЧАЙНЫЙ ВЫБОР</div>
    <div class="chip" id="btn-pack" style="display:none">УКЛАДКА: ПИРАМИДКА</div>
    <div class="chip" id="btn-cage" style="display:none">ПРУТЬЯ: ОБЫЧНАЯ</div>
    <div class="chip" id="btn-reset" style="display:none">RESET</div>
  </div>
  <div id="gas">GAS</div>
  <div id="result" class="hidden">
    <div class="card">
      <div class="ttl" id="res-ttl"></div>
      <div id="res-stats"></div>
      <div class="score">ИТОГ<b id="res-score">0</b></div>
    </div>
    <button id="res-restart">начать снова</button>
  </div>
</div>

<script>
const cv=document.getElementById('cv'),ctx=cv.getContext('2d');
let W,H,GY;
function resize(){
  const dpr=Math.min(window.devicePixelRatio||1,2);
  W=window.innerWidth;H=window.innerHeight;
  cv.width=W*dpr;cv.height=H*dpr;ctx.setTransform(dpr,0,0,dpr,0,0);
  GY=H*0.55;rebuild();
}

// ════════ РЕЛЬЕФ ════════
const STEP=5;
const SMOOTH_PASSES=5;           // проходов сглаживания рельефа (округляет крутые изломы; 0 = выкл)
let TERRAIN=[],TW=0,GOAL=6000,seed=12345,TERR_MODE='HILLS';   // 'PLAIN'|'HILLS'|'CLIFFS'
let finishSX=0, hangarX=0;       // мировой X начала финишной прямой и левого края ангара
let ramps=[], nextRamp=0;        // трамплины: список {x(лип),baseX,w,h,slope,type} и индекс следующего
let pits=[];                     // ямы: список {x0,x1} мировых границ (для отрисовки тьмы/кромок)
let arriveT=-1;                  // таймер паузы у ангара (ARRIVING); -1 = не активен
const FINISH_PAUSE=2.5;          // пауза от въезда до плашки результата, с (курьер дольше в кадре)
function rnd(){seed=(seed*9301+49297)%233280;return seed/233280;}
function rr(a,b){return a+(b-a)*rnd();}
const ss=t=>t*t*(3-2*t), easeOut=t=>1-Math.pow(1-t,2.2), easeIn=t=>Math.pow(t,2.2);
function makeFeats(mode){
  const U=H;let cy=0;const f=[];const cracks=[];
  ramps.length=0;                                    // трамплины пересобираются заново
  pits.length=0;                                     // ямы пересобираются заново
  const push=(type,w,dy,ex)=>{f.push({type,w,sy:cy,dy,...(ex||{})});cy+=dy;};
  const wsum=()=> f.reduce((a,s)=>a+s.w,0);          // суммарная длина уже наставленного
  // вспом. для регистрации декоративной щели в текущей точке x (заполним sx позже)
  const markCrack=(localList)=>localList.push({featIndex:f.length});
  push('FLAT',W*1.6,0);                              // стартовая площадка
  // ── ЯМА У СТАРТА (модуль C): разгон → НАСЫПЬ ЩЕБНЯ (скрытый мягкий подброс, без знака/рампы) → ПРОВАЛ → дальняя стена → площадка ──
  push('FLAT', W*1.1, 0);                            // разгон от старта к яме
  { const rkw=W*0.34, rkh=0.030*U;                   // плоская заплатка (smoothstep — без клевка перед прыжком)
    push('HILL', rkw, -rkh);
    const rlip=wsum();
    ramps.push({ x:rlip, baseX:rlip-rkw, w:rkw, h:rkh, slope:rkh/rkw, type:'rubble' });  // тип 'rubble' → drawRamps не рисует клин и знак
    const pitW=W*0.60, pitD=0.25*U;                  // ВАРИАНТ 3: средняя глубина; ШИРОКОЕ плоское дно — промазал прыжок, падаешь сюда РОВНО (без удара о стенку), −1 баллон
    const nearW=W*0.08, farW=W*0.22;                  // ближняя стена — крутой обрыв входа; дальняя (0.22W,~63°) — ПОЛОГАЯ, без рывка при взбирании
    const fx0=wsum()+nearW;                            // начало плоского дна (для камней)
    pits.push({ x0:wsum(), x1:wsum()+nearW+pitW+farW, fx0:fx0, fx1:fx0+pitW, depth:pitD });
    push('PEAK_DN', nearW, rkh+pitD);                 // ближняя стена: крутой обрыв входа
    push('FLAT', pitW, 0);                            // ШИРОКОЕ плоское дно ямы (с камнями)
    push('HILL', farW, -pitD);                        // дальняя стена; проём кромка→кромка ≈0.82W — перекрывается прыжком на скорости (+ coyote)
    push('FLAT', W*1.0, 0);                          // площадка приземления за ямой
  }
  const OBST_BUDGET=Math.max(W*2.5, 6000 - W*2.5);   // длина полосы препятствий (дальше — финишная прямая)
  if(mode==='PLAIN'){
    const b=[
      ()=>{push('HILL',rr(2.2,3.0)*W,-rr(0.06,0.12)*U);push('HILL',rr(2.2,3.0)*W,rr(0.06,0.12)*U);},
      ()=>{push('ROLL',rr(1.4,2.0)*W,rr(-0.05,0.05)*U);},
      ()=>{push('FLAT',rr(1.0,1.8)*W,0);},
    ];
    let gd=0;while(wsum()<OBST_BUDGET&&gd++<60){b[rnd()*b.length|0]();push('FLAT',rr(0.4,0.8)*W,0);}
  } else if(mode==='HILLS'){
    const b=[
      ()=>{push('PEAK_UP',rr(0.52,0.70)*W,-rr(0.22,0.32)*U);push('PEAK_DN',rr(0.52,0.70)*W,rr(0.24,0.34)*U);}, // трамплин-горб (положе, ниже)
      ()=>{push('VALLEY',rr(0.9,1.3)*W,0,{depth:rr(0.24,0.36)*U});},
      ()=>{push('HILL',rr(1.0,1.5)*W,-rr(0.18,0.26)*U);push('HILL',rr(0.55,0.75)*W,rr(0.30,0.40)*U);},          // взлёт + КРУТОЙ спуск (smoothstep: круто, но низ выполаживается)
      ()=>{push('STEP',rr(0.40,0.54)*W,-rr(0.14,0.24)*U);},                                                    // ступенька/обрывчик (положе)
      ()=>{push('PEAK_UP',rr(0.62,0.82)*W,-rr(0.20,0.28)*U);push('PEAK_DN',rr(0.62,0.82)*W,rr(0.20,0.28)*U);},
      ()=>{push('ROLL',rr(0.8,1.2)*W,rr(-0.10,0.10)*U);},
      // ярусный подъём на гору + ДЛИННЫЙ ЗАТЯЖНОЙ КРУТОЙ СПУСК (smoothstep: ~53° в середине → урон+тряска, низ плавный)
      ()=>{push('HILL',rr(0.7,0.9)*W,-rr(0.26,0.34)*U);push('HILL',rr(0.7,0.9)*W,-rr(0.26,0.34)*U);
           push('HILL',rr(1.05,1.35)*W,rr(0.55,0.72)*U);},
      // ВЫСОКИЙ ОБРЫВ: ярусный подъём + вершина + КРУТОЙ отвес (smoothstep ~62° в середине → азарт+урон, низ плавно выкатывается).
      ()=>{push('HILL',rr(0.6,0.8)*W,-rr(0.24,0.30)*U);push('HILL',rr(0.6,0.8)*W,-rr(0.24,0.30)*U);
           push('HILL',rr(0.6,0.8)*W,-rr(0.24,0.30)*U);push('FLAT',rr(0.2,0.4)*W,0);
           push('HILL',rr(0.85,1.05)*W,rr(0.64,0.74)*U);},
    ];
    let gd=0;while(wsum()<OBST_BUDGET&&gd++<60){b[rnd()*b.length|0]();push('FLAT',rr(0.12,0.30)*W,0);}
  } else { // CLIFFS
    const b=[
      ()=>{push('PEAK_UP',rr(0.50,0.68)*W,-rr(0.30,0.44)*U);push('PEAK_DN',rr(0.50,0.68)*W,rr(0.30,0.44)*U);},
      ()=>{push('VALLEY',rr(0.70,0.95)*W,0,{depth:rr(0.24,0.36)*U});},
      ()=>{push('HILL',rr(0.55,0.8)*W,-rr(0.22,0.34)*U);push('HILL',rr(0.5,0.75)*W,rr(0.22,0.34)*U);},
      ()=>{push('PEAK_DN',rr(0.6,0.8)*W,rr(0.26,0.38)*U);push('PEAK_UP',rr(0.55,0.72)*W,-rr(0.34,0.46)*U);},
      ()=>{push('STEP',rr(0.32,0.46)*W,-rr(0.16,0.26)*U);},
    ];
    let gd=0;while(wsum()<OBST_BUDGET&&gd++<60){
      b[rnd()*b.length|0]();
      if(rnd()>0.6)push('FLAT',rr(0.1,0.22)*W,0);
    }
  }
  push('HILL',W*1.5,-cy);                 // плавный возврат к базовому уровню

  // ── ТРАМПЛИН 1: земляной КЛИН (smoothstep) — пологий вылет ──
  push('FLAT', W*0.7, 0);                 // разгон
  let kw=W*0.40, kh=0.16*U;
  push('HILL', kw, -kh);
  let lip=wsum();
  ramps.push({ x:lip, baseX:lip-kw, w:kw, h:kh, slope:kh/kw, type:'wedge' });
  push('HILL', W*0.55, kh);               // спад за липом → разрыв
  push('FLAT', W*0.85, 0);                // площадка приземления

  // ── ТРАМПЛИН 2: вогнутая «СКЕЙТОВАЯ» дуга (RAMPC) — выше и вертикальнее ──
  push('FLAT', W*0.8, 0);                 // разгон
  kw=W*0.34; kh=0.20*U;
  push('RAMPC', kw, -kh);                 // вогнутый взлёт (круто у губы)
  lip=wsum();
  ramps.push({ x:lip, baseX:lip-kw, w:kw, h:kh, slope:kh/kw, type:'curve' });
  push('HILL', W*0.6, kh);                // спад за липом
  push('FLAT', W*0.9, 0);                 // площадка приземления

  push('HILL', W*0.6, 0);                  // короткий ровный подход
  finishSX = wsum();                       // мировой X начала ровной финишной прямой
  push('FLAT',W*3.2,0);                    // длинная ровная финишная прямая (как старт)
  let x=0;f.forEach(s=>{s.sx=x;x+=s.w;});TW=x;
  hangarX = finishSX + W*0.9;              // левый край ангара (открытый въезд)
  GOAL    = finishSX + W*1.0;              // финиш — у въезда в ангар
  return {feats:f};
}
function buildProfile(){
  const {feats}=makeFeats(TERR_MODE);
  TERRAIN=[];let fi=0;
  for(let px=0;px<=TW;px+=STEP){
    while(fi<feats.length-1&&px>=feats[fi].sx+feats[fi].w)fi++;
    const f=feats[fi],t=Math.min(1,(px-f.sx)/f.w);let y;
    switch(f.type){
      case'FLAT':y=f.sy;break;
      case'HILL':case'ROLL':case'STEP':y=f.sy+f.dy*ss(t);break;
      case'RAMPC':y=f.sy+f.dy*easeIn(t);break;            // вогнутая «скейтовая» дуга: круто загибается у губы
      case'DROP':y=f.sy+f.dy*easeOut(t);break;            // крутой спуск сверху → мягкий выкат у ровной земли (азарт+тряска, но без резкого угла внизу)
      case'PEAK_UP':y=f.sy+f.dy*easeOut(t);break;
      case'PEAK_DN':y=f.sy+f.dy*easeIn(t);break;
      case'VALLEY':{
        const edge=0.30;let k;
        if(t<edge)k=ss(t/edge);else if(t>1-edge)k=ss((1-t)/edge);else k=1;
        y=f.sy+k*f.depth;break;
      }
      default:y=f.sy;
    }
    TERRAIN.push(y);   // ФИЗИКА: поверхность гладкая
  }
  // СГЛАЖИВАНИЕ резких углов: мягкое усреднение [0.25,0.5,0.25] несколько раз.
  // На прямом склоне значение не меняется (линейно) — трогает только изломы и самые крутые загибы,
  // округляя их (мягче въезд на крутые холмы; устойчивее физика в яме — нет резких скачков оси).
  for(let pass=0; pass<SMOOTH_PASSES; pass++){
    const T=TERRAIN, n=T.length, out=T.slice();
    for(let i=1;i<n-1;i++) out[i]=0.25*T[i-1]+0.5*T[i]+0.25*T[i+1];
    TERRAIN=out;
  }
}
// ghost-прогон: полный газ от старта до Б → идеальное (минимальное) время трассы, сек.
// КЛОББЕРИТ игровое состояние, поэтому вызывается из rebuild ПЕРЕД финальным сбросом.
function measureParTime(){
  scroll=0;speed=0;camY=null;bike.init=false;bike.airborne=false;bike.vy=0;
  nextRamp=0;startMoved=false;launchWheelie=0;pitEjected=false;ejected=null;
  forkTravel=0;forkVel=0;flapAng=0;flapVel=0;bounce=0;bounceV=0;bar=0;barV=0;wheelie=0;slip=0;slopeShake=0;slopeAccum=0;prevGroundAng=0;prevAxleY=null;
  loadCargo();
  const gs=gameState; gameState='RIDING';
  let t=0, ok=false;
  for(let i=0;i<20000;i++){ gasHeld=true; updatePhysics(1/60); t+=1/60; if(scroll+CX()>=GOAL){ ok=true; break; } }
  gameState=gs; gasHeld=false;
  return ok ? t : GOAL/PAR_K;                    // запасной вариант, если ghost не доехал
}
function rebuild(){
  seed=(Math.random()*99999)|0; buildProfile();
  CARGO_MAX = 1 + Math.floor(Math.random()*3);   // задача: довезти 1..3 баллона
  parTime = measureParTime();                    // идеальное время этой трассы (ghost, полный газ)
  timeLimit = Math.max(12, Math.round(parTime * TIGHT));  // ТУГОЙ лимит = идеал × TIGHT
  // ПОЛНЫЙ сброс состояния для реального заезда (после ghost-прогона):
  scroll=0;speed=0;camY=null;bike.init=false;bike.airborne=false;bike.vy=0;parts.length=0;emit=0;wheelie=0;slip=0;forkTravel=0;forkVel=0;flapAng=0;flapVel=0;bounce=0;bounceV=0;bar=0;barV=0;ejected=null;slopeShake=0;tapeBroken=false;prevAng=0;prevAxleY=null;dmgLog.length=0;dmgJump=0;dmgSlope=0;slopeAccum=0;arriveT=-1;nextRamp=0;launchWheelie=0;startMoved=false;prevGroundAng=0;pitEjected=false;
  loadCargo();                                   // грузим CARGO_MAX свежих баллонов
  rideTime=0; result=null;                       // обнуляем таймер и итог уровня
  hideResult();                                  // на случай ресайза поверх экрана результата
}
function terrY(worldX){
  const tw=TW;let x=((worldX%tw)+tw)%tw;
  const i=Math.floor(x/STEP),t=(x-i*STEP)/STEP,n=TERRAIN.length;
  return GY+TERRAIN[i%n]+(TERRAIN[(i+1)%n]-TERRAIN[i%n])*t;
}

// ════════ СОСТОЯНИЕ ИГРЫ (модель заезда: уровни-доставки) ════════
// READY → RIDING → DELIVERED | FAILED
let gameState='READY';
// ── груз: баллоны O₂, которые везём из А в Б ──
let cargo=0;            // сколько баллонов на байке сейчас (= tanks.length)
let CARGO_MAX=3;       // ЗАДАЧА уровня: сколько довезти (1..3, рандом в rebuild); грузим столько же
const DEPRESS_TH=0.72; // урон ≥72% → баллон разгерметизирован (красная линия), на финише НЕ засчитан довезённым
let timeLimit=40;      // лимит времени на заезд, сек (рандом в rebuild)
// расшатанность каждого баллона 0..1: копится от тряски/ударов (необратимо).
// tanks — ДИНАМИЧЕСКИЙ массив (длина = cargo); вылет убирает баллон из массива.
let tanks=[];
