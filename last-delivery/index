// ── подсчёт итога уровня и показ экрана результата ──
function finishLevel(state){
  // довезёнными считаем только баллоны с уроном < порога разгерметизации; разгерметизированный = потерян
  const delivered = tanks.filter(t=> t.w < DEPRESS_TH).length;
  if(state==='DELIVERED' && delivered===0) state='FAILED';   // ничего целого не довезли → провал
  setState(state);
  // сохранность = средняя целостность по слотам (разгерметизированный/вылетевший слот = 0)
  let intg=0; tanks.forEach(t=> intg += (t.w < DEPRESS_TH) ? Math.max(0,1-t.w) : 0); intg/=CARGO_MAX;
  const bonus=(state==='DELIVERED') ? Math.max(0, Math.round((timeLimit-rideTime)*BONUS_K)) : 0;  // бонус = остаток времени × BONUS_K
  const score=(state==='DELIVERED') ? Math.round(intg*1000)+bonus : 0;
  result={ state, delivered, intg, time:rideTime, bonus, score,
           dmgJump:Math.round(dmgJump*100), dmgSlope:Math.round(dmgSlope*100) };
  showResult();  // блюр + плашка результата + кнопка «начать снова»
}
function showResult(){
  if(!result)return;
  const r=result, box=document.getElementById('result');
  document.getElementById('res-ttl').textContent = r.state==='DELIVERED'?'ДОСТАВЛЕНО':'ПРОВАЛ';
  box.classList.remove('win','lose'); box.classList.add(r.state==='DELIVERED'?'win':'lose');
  const row=(k,v)=>`<div class="row"><span>${k}</span><b>${v}</b></div>`;
  document.getElementById('res-stats').innerHTML=
    row('довезено', r.delivered+' / '+CARGO_MAX)+
    row('сохранность', Math.round(r.intg*100)+'%')+
    row('урон: прыжки', r.dmgJump+'%')+
    row('урон: спуски', r.dmgSlope+'%')+
    row('время', r.time.toFixed(1)+' с'+(r.bonus>0?'  (+'+r.bonus+')':''));
  document.getElementById('res-score').textContent = r.score;
  box.classList.remove('hidden');
}
