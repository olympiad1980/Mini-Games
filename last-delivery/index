function drawArm2(spine,col){
  const L=[],Rr=[];
  for(let i=0;i<spine.length;i++){
    const a=spine[Math.max(0,i-1)], b=spine[Math.min(spine.length-1,i+1)];
    let tx=b.x-a.x, ty=b.y-a.y, len=Math.hypot(tx,ty)||1; tx/=len; ty/=len;
    const nx=-ty, ny=tx, hw=spine[i].w/2;
    L.push({x:spine[i].x+nx*hw, y:spine[i].y+ny*hw});
    Rr.push({x:spine[i].x-nx*hw, y:spine[i].y-ny*hw});
  }
  const poly=L.concat(Rr.reverse());
  ctx.fillStyle=col;ctx.beginPath();
  ctx.moveTo((poly[poly.length-1].x+poly[0].x)/2,(poly[poly.length-1].y+poly[0].y)/2);
  for(let i=0;i<poly.length;i++){const n=poly[(i+1)%poly.length];
    ctx.quadraticCurveTo(poly[i].x,poly[i].y,(poly[i].x+n.x)/2,(poly[i].y+n.y)/2);}
  ctx.closePath();ctx.fill();
}
