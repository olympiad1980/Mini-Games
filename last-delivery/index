  ctx.quadraticCurveTo(armSh.x+3, armSh.y-3, armSh.x+4.5, armSh.y+1.5);
  ctx.stroke();
  // ── ШЕЯ: тонкий столбик, лишь чуть темнее тела; без тёмной линии сзади ──
  const NK='#c0976e';                                 // ближе к цвету тела (едва темнее)
  const neckBase={x: sh.x + ax*0.5, y: sh.y + ay*0.5};                 // низ шеи = верх торса
  const headBot ={x: hd.x - Math.sin(hL)*6, y: hd.y + Math.cos(hL)*6}; // верх шеи (под подбородком)
  const nPx=Math.cos(hL), nPy=Math.sin(hL);
