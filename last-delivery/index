    const RT=[HINGE[0]+dxr*ca-dyr*sa, HINGE[1]+dxr*sa+dyr*ca];  // длинная часть качается вокруг вершины
    const lerp=(a,b,t)=>[a[0]+(b[0]-a[0])*t, a[1]+(b[1]-a[1])*t];
    const mv=p=>ctx.lineTo(p[0],p[1]);
    // ── ЗАД КЛЕТКИ привязан к оси заднего колеса → проседает с амортизацией ──
    const RAXc={x:-HALF, y:LIFT-forkTravel};             // реальная ось заднего колеса (с ходом подвески)
    const rearSag=-forkTravel*0.45;                      // зад клетки следует за осью (вверх при сжатии)
