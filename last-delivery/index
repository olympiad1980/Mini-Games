  ctx.moveTo(2,-31);
  ctx.quadraticCurveTo(2,-44,14,-45);
  ctx.quadraticCurveTo(24,-45,23,-35);
  ctx.quadraticCurveTo(22,-31,14,-31);
  ctx.closePath();ctx.fill();
  ctx.fillStyle=RUST.tankHi;ctx.beginPath();ctx.ellipse(12,-41,6,2.4,-0.2,0,7);ctx.fill(); // блик
  ctx.fillStyle=RUST.steelDk;ctx.beginPath();ctx.arc(20,-34,1.6,0,7);ctx.fill();            // крышка

  // ── длинное плоское седло (тонкое) ──
  ctx.fillStyle=RUST.seat;ctx.beginPath();
  ctx.moveTo(0,-33);ctx.lineTo(-32,-32);ctx.quadraticCurveTo(-38,-32,-38,-29);
  ctx.lineTo(-2,-30);ctx.closePath();ctx.fill();
  ctx.fillStyle=RUST.seatHi;ctx.fillRect(-30,-32,24,1.4);






  drawRider();                               // курьер (физика по riderPose)

  // ── СЕТКА ПОД БАЛЛОНЫ (кривой самосварной каркас по эскизу; за седлом, над колесом) ──
  {
    // неровные углы; задний торец уехал назад (за выхлоп, который кончается ≈-62)
    const FB=[-26+CAGE_DX,-25], FT=[-28+CAGE_DX,-55], RB=[-78+CAGE_DX,-22];
    const APEX=[-38+CAGE_DX,-65];                         // ВЕРШИНА поднята (зазор под стоячие баллоны)
    const HINGE=APEX;                                     // крышка крепится к вершине
    const RTrest=[-80+CAGE_DX,-57];                      // покой: длинная грань идёт назад-вниз от вершины
    const ca=Math.cos(flapAng), sa=Math.sin(flapAng);
