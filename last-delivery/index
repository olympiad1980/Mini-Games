const CX=()=>W*0.38;
const HALF=48, WR=20;
const ENG=900, GRAV_ROLL=1300, DRAG=1.5, SPD_MIN=-300, SPD_MAX=760, JUMP_MIN_SPD=70;  // GRAV_ROLL≫ENG → даже умеренный подъём тормозит, не «залетаешь»
