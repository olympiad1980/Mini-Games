  const thighLen=22, shinLen=21;
  const knee=ik2(hip.x,hip.y, peg.x,peg.y, thighLen,shinLen, -1);  // колено вперёд
  // ПЛЕЧО опущено вниз от верха торса (sh) → открывается шея; дельта/рука висят ниже
  const armSh={x: sh.x+1.5, y: sh.y+1.5};   // плечо выше → размах руки до руля больше
