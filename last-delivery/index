      landingPuff(s.rx,s.gR,Math.min(1,impact/600));       // пыль/камни от удара
      forkVel += Math.min(300, impact*0.7);                // просадка заднего: толчок сжатия (как в старом — идеально)
      flapVel -= Math.min(9, impact*0.022);                // удар подкидывает крышку сетки
      barV    -= Math.min(150, impact*0.16);
      const hv=Math.min(130, impact*0.14);                 // одиночный подскок каждому баллону
      tanks.forEach((t,k)=>{ t.hopV=hv*(0.7+0.5*Math.abs(Math.sin(t.ph*2.7))); t.hopDelay=Math.random()*0.09; });
      const over=Math.max(0, impact-153);
      const kick=Math.min(0.22, over*over*0.0000001808);
      const tp=topTankIdx();
      const _wxL=scroll+cx, _pitL=pits.find(p=> _wxL>p.x0 && _wxL<p.x1);
      if(_pitL){
        // В ЯМЕ: если БАЙК завалился в яму (сел заметно ниже кромки, а не перепрыгнул чисто) — вылетает ровно ОДИН баллон.
        // Чисто перепрыгнул (полный газ/прыжок) — провала нет, баллон цел. Остальные баллоны в яме НЕ повреждаем.
        if(!pitEjected && (bike.axleY-GY) > 0.30*_pitL.depth && tanks.length>0){
          tanks[topTankIdx()].w=1; pitEjected=true; logEvent('УПАЛ В ЯМУ', Math.round(impact), 1);
        }
      } else {
        tanks.forEach((t,i)=>{ t.w=Math.min(1, t.w + kick*(i===tp?1.15:0.9)*t.dm); });
        if(kick>0.0005){ dmgJump+=kick; logEvent('ПРЫЖОК', Math.round(impact), kick); }
      }
      slopeAccum=0;                                         // спуск завершился приземлением
      rHopV = Math.min(90, impact*0.13); rHopDelay = 0.12;  // подскок курьера
    }
  } else {
    bike.axleY=groundAxleY;
    bike.ang+=(groundAng-bike.ang)*Math.min(1,18*dt);  // быстрое следование рельефу (как в рабочем старом файле)
  }
  if(!bike.airborne) coyote=COYOTE_T; else coyote=Math.max(0, coyote-dt);  // grace-окно прыжка после отрыва

  prevGroundAng = groundAng;                 // для гашения при выполаживании в следующем кадре
  // вылет баллона происходит ТОЛЬКО при приземлении на ДНО ямы (см. блок приземления выше).
  // Здесь — лишь сброс флага, когда выехал из ямы на ровное (готов к следующей яме, если будет).
  if((bike.axleY-GY) < 0.10*H) pitEjected=false;
  const a=bike.ang, axleY=bike.axleY;
  // ── ход задней подвески: пружина-демпфер к статике; толчок при приземлении ──
  forkVel += ((0-forkTravel)*260 - forkVel*16)*dt;
  forkTravel += forkVel*dt;
  forkTravel = Math.max(-8, Math.min(30, forkTravel));   // потолок просадки (как в старом — идеально)
  // ── хлоп задней крышки сетки: жёсткая пружина + сильный демпфер = металлич. дребезг ──
  // (крышка — единственный реально подвижный элемент; бьётся резко и быстро затухает)
  const shake = bike.airborne ? 0 : Math.abs(speed)*0.05*(0.6+slip*0.05);
  flapVel += ((0-flapAng)*420 - flapVel*7)*dt + (Math.random()-0.5)*shake*dt;
  flapAng += flapVel*dt;
  flapAng = Math.max(-0.805, Math.min(0.115, flapAng));  // амплитуда качания +15%
  // подскок груза/перегородок: пружина к покою + демпфер (импульс от приземления затухает)
  bounceV += ((0-bounce)*246 - bounceV*6)*dt;
  bounce += bounceV*dt;
  bounce = Math.max(-26, Math.min(12, bounce));        // потолок хода подскока
  barV += ((0-bar)*330 - barV*8)*dt;                   // планка: жёстче пружина + сильнее демпфер → иной ритм
  bar += barV*dt;
  bar = Math.max(-12, Math.min(6, bar));
  // одиночный подскок баллонов: дуга вверх-вниз (скорость+гравитация), один раз, без колебаний
  tanks.forEach(t=>{
    if(t.hopDelay>0){ t.hopDelay-=dt; return; }
    if(t.hopV!==0 || t.hop>0){
      t.hop += t.hopV*dt; t.hopV -= 620*dt;              // гравитация подскока
      if(t.hop<=0){ t.hop=0; t.hopV=0; }                 // приземлился — стоп (без отскока)
    }
  });
  tSec += dt;                                            // глобальное время для дребезга прутьев
  // ── РАСШАТАННОСТЬ (заход 1): падение носом / крутой спуск — по скорости снижения ──
  // сигнал = как быстро БАЙК ТЕРЯЕТ ВЫСОТУ на земле (надёжнее угла: ловит и спуск, и падение
  // в яму). Подъём вверх / прямая / газ — высота не падает → урон 0. Перегазовка убрана.
  let rough=0;
  if(!bike.airborne){
    // урон спуска от КРУТИЗНЫ угла (не от скорости снижения — иначе длинный разгонный
    // спуск накручивал урон скоростью). Порог 44°: пологие/средние = 0, круче 44° копит.
    const TH=0.838;                                          // 48°: умеренные склоны безопасны, штраф с отвесов
    if(bike.ang>TH){
