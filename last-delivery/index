    t.w = Math.max(0, Math.min(1, t.w));                  // урон НЕОБРАТИМ
  });
  // ── ВЫЛЕТ: любой баллон достиг 100% → вылетает через открытый зад, убирается из клетки ──
  if(!ejected){
    const ei=tanks.findIndex(t=>t.w>=1);
    if(ei>=0){
      const L=layoutNow(), pos=L[ei]||L[0];               // локальная позиция этого баллона в клетке
      const lx=pos[0]+CAGE_DX, ly=pos[1]-16;               // -16 = клиренс (LIFT), +сдвиг клетки
      const ex = cx + lx*Math.cos(a) - ly*Math.sin(a);     // в экранные координаты (как частицы)
      const ey = axleY + lx*Math.sin(a) + ly*Math.cos(a);
      ejected = { x:ex, y:ey, vx:-40-Math.random()*40, vy:-230-Math.random()*70,
                  rot:a, vrot:(Math.random()-0.5)*7, life:3.4, landed:false };
      tanks.splice(ei,1); cargo=tanks.length; tanksLost++;  // баллон покинул клетку → груз −1, слот в HUD гаснет
      bounceV-=140;                                        // толчок оставшегося груза
    }
  }
  // ── вилли: пивот вокруг заднего колеса, переднее приподнимается ──
  const w=bike.airborne?0:wheelie;
  const aEff=a-w;                                   // нос вверх
  const rx=cx-HALF*Math.cos(a), ry=axleY-HALF*Math.sin(a);   // заднее колесо остаётся на месте
  const axCx=rx+HALF*Math.cos(aEff), axCy=ry+HALF*Math.sin(aEff);
  // заднее колесо смещается на величину хода подвески (пивот вилли остаётся жёстким — rx,ry)
  const upx=Math.sin(aEff), upy=-Math.cos(aEff);
  const rxd=rx+upx*forkTravel, ryd=ry+upy*forkTravel;
  const fxd=rx+2*HALF*Math.cos(aEff), fyd=ry+2*HALF*Math.sin(aEff);
  // ── ФИЗИКА КУРЬЕРА: в воздухе встаёт на почти прямые ноги; на земле садится и подскакивает 1 раз ──
  rAir = bike.airborne ? rAir+dt : 0;                     // длительность текущего полёта
  const standTarget = bike.airborne ? Math.min(6.5, 5.5 + rAir*2.5) : 0; // в воздухе — почти прямые ноги
  rStandV += ((standTarget - rStand)*250 - rStandV*25)*dt; // быстрая чистая посадка на сиденье (без болтанки)
  rStand += rStandV*dt;
  rStand = Math.max(-3, Math.min(7, rStand));
  riderPose.stand = rStand;
  // одиночный подскок при приземлении — баллистическая дуга с задержкой (сперва сел, потом 1 подскок вверх; как баллоны)
  if(rHopDelay>0){ rHopDelay -= dt; }
  else if(rHopV!==0 || rHop>0){ rHop += rHopV*dt; rHopV -= 520*dt; if(rHop<=0){rHop=0; rHopV=0;} } // дуга подскока
  riderPose.hop = -rHop;                                   // вверх (hip.y = -34 - stand + hop)
  // наклон от ускорения: разгон → корпус назад (меньше lean), торможение/сброс → клюёт вперёд
  const acc=(speed - rPrevSpeed)/Math.max(dt,0.001); rPrevSpeed=speed;
  rAccel += (acc - rAccel)*Math.min(1, dt*6);
  let leanT = 0.56 - Math.max(-0.10, Math.min(0.16, rAccel*0.00035)); // сидя сильнее наклонён вперёд (сгорблен)
  if(bike.airborne) leanT = Math.min(0.50, 0.44 + rAir*0.06); // в полёте умеренный наклон вперёд (плечи позади руля → рука вниз-вперёд)
  rLean += (leanT - rLean)*Math.min(1, dt*7);
  riderPose.lean = rLean;
  riderPose.shake = slopeShake;                            // тряска только на штрафном спуске → вторичка фигуры

  return {cx:axCx,a:aEff,axleY:axCy,cy:axCy-16,
    rear:{x:rxd,y:ryd},
    front:{x:fxd,y:fyd},
    gR:s.gR,gF:s.gF};
}
