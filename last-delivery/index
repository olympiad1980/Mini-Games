}
// ── НАСЫПЬ ЩЕБНЯ у ямы: свежая рыхлая земля + несколько камней (вид недавнего ремонта) ──
function drawRubble(r){
  const lx=r.x-scroll, bx=r.baseX-scroll;
  if(lx<-160 || bx>W+200) return;
  const x0=r.baseX-W*0.06, x1=r.x+W*0.05;
  ctx.save();
  // патч свежей (более светлой) земли по поверхности насыпи
  ctx.fillStyle='#7d5a30';
  ctx.beginPath(); ctx.moveTo(x0-scroll, terrY(x0));
  for(let wx=x0; wx<=x1; wx+=5) ctx.lineTo(wx-scroll, terrY(wx));
  ctx.lineTo(x1-scroll, terrY(x1)+10); ctx.lineTo(x0-scroll, terrY(x0)+10); ctx.closePath(); ctx.fill();
  // крапины рыхлости (темнее/светлее) — фактура свежей насыпи
  ctx.fillStyle='rgba(58,38,18,0.5)';
  for(let i=0;i<16;i++){ const wx=x0+(x1-x0)*((i*0.137)%1); ctx.fillRect(wx-scroll, terrY(wx)+2+((i*53)%11), 2.3,2.3); }
  ctx.fillStyle='rgba(196,156,96,0.45)';
  for(let i=0;i<12;i++){ const wx=x0+(x1-x0)*((i*0.221+0.07)%1); ctx.fillRect(wx-scroll, terrY(wx)+1+((i*37)%8), 1.8,1.8); }
  // несколько небольших камней, разбросаны по заплатке
  const rocks=[[0.10,2,6],[0.28,-1,9],[0.44,3,5],[0.58,1,7],[0.72,4,6],[0.86,2,5],[0.20,5,4],[0.64,-2,8]];
  rocks.forEach(([t,dy,rad])=>{ const wx=x0+(x1-x0)*t, x=wx-scroll, y=terrY(wx)+dy;
    ctx.fillStyle='#8b8178'; ctx.beginPath(); ctx.ellipse(x,y,rad,rad*0.78,0.3,0,7); ctx.fill();
    ctx.fillStyle='rgba(255,255,255,0.18)'; ctx.beginPath(); ctx.ellipse(x-rad*0.3,y-rad*0.32,rad*0.4,rad*0.3,0.3,0,7); ctx.fill();
    ctx.fillStyle='rgba(0,0,0,0.22)';      ctx.beginPath(); ctx.ellipse(x+rad*0.2,y+rad*0.34,rad*0.5,rad*0.3,0.3,0,7); ctx.fill();
  });
  ctx.restore();
}
// ── ТРАМПЛИНЫ: земляная насыпь-клин с кромкой ──
function drawRamps(){
  for(const r of ramps){
    if(r.type==='rubble'){ drawRubble(r); continue; }   // насыпь щебня: свой рисунок, без клина и без знака
    const bx=r.baseX-scroll, lx=r.x-scroll;
    if(lx<-120 || bx>W+200) continue;
    const gyBase=terrY(r.baseX), gyLip=terrY(r.x);
    ctx.save();
    // тело насыпи: верх — ТОЧНО по реальной поверхности (terrY), низ — горизонт базы
    ctx.fillStyle = r.type==='curve' ? '#4c4844' : '#5a4632';   // дуга — серый «бетон/металл», клин — земля
    ctx.beginPath(); ctx.moveTo(bx,gyBase);
    for(let wx=r.baseX; wx<=r.x; wx+=6) ctx.lineTo(wx-scroll, terrY(wx));   // накат по земле
    ctx.lineTo(lx,gyBase); ctx.closePath(); ctx.fill();
    ctx.fillStyle='rgba(0,0,0,0.18)';                     // тень у схода (за липом)
    ctx.beginPath(); ctx.moveTo(lx,gyLip); ctx.lineTo(lx,gyBase); ctx.lineTo(lx+12,gyBase); ctx.closePath(); ctx.fill();
    ctx.strokeStyle='#8a6a3a'; ctx.lineWidth=3; ctx.lineCap='round';        // верхняя кромка (накат), по земле
    ctx.beginPath(); ctx.moveTo(bx,gyBase);
    for(let wx=r.baseX; wx<=r.x; wx+=6) ctx.lineTo(wx-scroll, terrY(wx));
    ctx.stroke();
    ctx.strokeStyle='rgba(0,0,0,0.16)'; ctx.lineWidth=1.4;                  // поперечные доски
    for(let t=0.25;t<1;t+=0.25){ const wx=r.baseX+(r.x-r.baseX)*t;
      ctx.beginPath(); ctx.moveTo(wx-scroll, terrY(wx)); ctx.lineTo(wx-scroll, gyBase); ctx.stroke(); }
    ctx.fillStyle='#caa050';                              // отметка-лип на гребне
    ctx.fillRect(lx-2, gyLip-7, 4, 9);
    if(r.type==='curve'){                                 // копинг — металлическая труба на губе (скейт-рампа)
      ctx.fillStyle='#c2cad0'; ctx.strokeStyle='#6b7178'; ctx.lineWidth=1.6;
      ctx.beginPath(); ctx.arc(lx, gyLip-3, 5, 0, 7); ctx.fill(); ctx.stroke();
      ctx.fillStyle='rgba(255,255,255,0.5)'; ctx.beginPath(); ctx.arc(lx-1.6, gyLip-4.4, 1.6, 0, 7); ctx.fill(); // блик
    }
    ctx.restore();
    drawWarnSign(r.baseX - W*0.55);                       // знак «обрыв» перед рампой
  }
}
// ── помятый предупредительный знак «ОБРЫВ» (классический треугольник, заброшенный вид) ──
function drawWarnSign(worldX){
  const sx=worldX-scroll; if(sx<-60||sx>W+60) return;
  const gy=terrY(worldX), lean=0.08;                     // лёгкий наклон столба
  ctx.save(); ctx.translate(sx,gy); ctx.rotate(lean);
  // столб (ржавая труба)
  ctx.strokeStyle='#6b5a44'; ctx.lineWidth=4; ctx.lineCap='round';
  ctx.beginPath(); ctx.moveTo(0,0); ctx.lineTo(0,-58); ctx.stroke();
  ctx.strokeStyle='rgba(90,45,20,0.5)'; ctx.lineWidth=1.6;                // ржавый потёк
  ctx.beginPath(); ctx.moveTo(1.5,-20); ctx.lineTo(1.5,-2); ctx.stroke();
  // треугольная табличка (равносторонняя, остриём вверх), чуть подвёрнута
  ctx.translate(0,-58); ctx.rotate(0.06); const R=21;
  const p=[[0,-R],[R*0.87,R*0.5],[-R*0.87,R*0.5]];
  ctx.beginPath(); ctx.moveTo(p[0][0],p[0][1]); ctx.lineTo(p[1][0],p[1][1]); ctx.lineTo(p[2][0],p[2][1]); ctx.closePath();
  ctx.fillStyle='#c8a13a'; ctx.fill();                                   // выцветший жёлтый
  ctx.lineWidth=4; ctx.strokeStyle='#7a2418'; ctx.stroke();              // тёмно-красная кайма
  ctx.lineWidth=2.5; ctx.strokeStyle='#241a10';                          // внутренняя обводка
  ctx.beginPath(); ctx.moveTo(p[0][0],p[0][1]+5); ctx.lineTo(p[1][0]-4,p[1][1]-3); ctx.lineTo(p[2][0]+4,p[2][1]-3); ctx.closePath(); ctx.stroke();
  // пиктограмма «обрыв»: кромка земли + стрелка вниз в провал
  ctx.strokeStyle='#241a10'; ctx.lineWidth=2.4; ctx.lineCap='round'; ctx.lineJoin='round';
  ctx.beginPath(); ctx.moveTo(-9,2); ctx.lineTo(0,2); ctx.lineTo(0,9); ctx.stroke();     // полка обрыва
  ctx.beginPath(); ctx.moveTo(6,-4); ctx.lineTo(6,9); ctx.moveTo(2.5,5); ctx.lineTo(6,9); ctx.lineTo(9.5,5); ctx.stroke(); // стрелка вниз
  // заброшенность: трещина, отбитый угол, дырка от пули
  ctx.strokeStyle='rgba(0,0,0,0.4)'; ctx.lineWidth=1.4;
  ctx.beginPath(); ctx.moveTo(-3,-12); ctx.lineTo(2,-2); ctx.lineTo(-1,4); ctx.stroke();  // трещина
  ctx.fillStyle='#3a3250';                                              // отбитый угол (видно небо)
  ctx.beginPath(); ctx.moveTo(p[1][0],p[1][1]); ctx.lineTo(p[1][0]-7,p[1][1]); ctx.lineTo(p[1][0]-1,p[1][1]-6); ctx.closePath(); ctx.fill();
  ctx.fillStyle='#1a130c'; ctx.beginPath(); ctx.arc(-7,-1,2,0,7); ctx.fill();             // пулевое отверстие
  ctx.strokeStyle='rgba(0,0,0,0.3)'; ctx.lineWidth=0.8; ctx.beginPath(); ctx.arc(-7,-1,3.4,0,7); ctx.stroke();
  ctx.restore();
}
// ════════ ФИНИШ — заброшенный ангар на ровной прямой (гофрокрыша, открытый въезд) ════════
function drawHangar(){
  const hx=hangarX-scroll, Lh=W*1.5, Hh=Math.min(170,W*0.42);
  if(hx>W+90||hx+Lh<-90) return;
  const gy=terrY(hangarX), x0=hx, x1=hx+Lh, mid=(x0+x1)/2;
  const shoulder=gy-Hh*0.5, crown=gy-Hh;
  const body=()=>{ ctx.beginPath(); ctx.moveTo(x0,gy); ctx.lineTo(x0,shoulder);
    ctx.quadraticCurveTo(mid,2*crown-shoulder,x1,shoulder); ctx.lineTo(x1,gy); ctx.closePath(); };
  ctx.save(); ctx.lineJoin='round';
  // глубина: тёмный торец справа-сверху
  const dx=Lh*0.12, dy=-Hh*0.06;
  ctx.fillStyle='#403930'; ctx.beginPath();
  ctx.moveTo(x1,shoulder); ctx.quadraticCurveTo(mid,2*crown-shoulder,x0,shoulder);
  ctx.lineTo(x0+dx,shoulder+dy); ctx.quadraticCurveTo(mid+dx,2*crown-shoulder+dy,x1+dx,shoulder+dy);
  ctx.lineTo(x1+dx,gy+dy); ctx.lineTo(x1,gy); ctx.closePath(); ctx.fill();
  // корпус с гофрой
  ctx.save(); body(); ctx.clip();
  let g=ctx.createLinearGradient(0,crown,0,gy); g.addColorStop(0,'#857c6f'); g.addColorStop(1,'#675e50');
  ctx.fillStyle=g; ctx.fillRect(x0-2,crown-2,Lh+4,gy-crown+4);
  for(let xx=x0+3; xx<x1; xx+=8){
    ctx.strokeStyle='rgba(0,0,0,0.14)'; ctx.lineWidth=2.4; ctx.beginPath(); ctx.moveTo(xx,crown-4); ctx.lineTo(xx,gy); ctx.stroke();
    ctx.strokeStyle='rgba(255,255,255,0.05)'; ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(xx+2.4,crown-4); ctx.lineTo(xx+2.4,gy); ctx.stroke();
  }
  for(let k=0;k<5;k++){ const step=(shoulder-crown)/5, sh=shoulder-k*step;
    ctx.strokeStyle='rgba(0,0,0,0.10)'; ctx.lineWidth=1; ctx.beginPath();
    ctx.moveTo(x0,sh); ctx.quadraticCurveTo(mid,2*(crown-k*step)-sh,x1,sh); ctx.stroke(); }
  ctx.restore();
  ctx.strokeStyle='#4f473c'; ctx.lineWidth=2; body(); ctx.stroke();
  // проём (открытый въезд, без ворот)
  const fr=Lh*0.135, ox0=x0+fr, ox1=x1-fr, omid=(ox0+ox1)/2, oSh=gy-Hh*0.42, oCr=crown+fr*0.7;
  const open=()=>{ ctx.beginPath(); ctx.moveTo(ox0,gy); ctx.lineTo(ox0,oSh);
    ctx.quadraticCurveTo(omid,2*oCr-oSh,ox1,oSh); ctx.lineTo(ox1,gy); ctx.closePath(); };
  ctx.strokeStyle='#938878'; ctx.lineWidth=5; open(); ctx.stroke();   // рамка проёма
  ctx.save(); open(); ctx.clip();
  let gi=ctx.createLinearGradient(0,oCr,0,gy); gi.addColorStop(0,'#0e0b08'); gi.addColorStop(1,'#221b14');
  ctx.fillStyle=gi; ctx.fillRect(ox0-2,oCr-2,ox1-ox0+4,gy-oCr+4);
  ctx.fillStyle='rgba(120,100,70,0.12)'; ctx.fillRect(ox0,gy-22,ox1-ox0,22);   // слабый свет пола
  ctx.restore();
  // заброшенность: потёки, ржавчина, дыры
  ctx.strokeStyle='rgba(86,42,18,0.34)'; ctx.lineWidth=2.4;
  [x0+18,x1-22,mid-30,mid+40].forEach(sx=>{ ctx.beginPath(); ctx.moveTo(sx,shoulder-12); ctx.lineTo(sx,shoulder+45); ctx.stroke(); });
  [['rgba(120,60,30,0.30)',x0+24,shoulder+10,15,9],['rgba(95,45,22,0.34)',x1-30,gy-44,17,12],['rgba(140,80,40,0.26)',mid+20,crown+24,20,10]]
    .forEach(b=>{ ctx.fillStyle=b[0]; ctx.beginPath(); ctx.ellipse(b[1],b[2],b[3],b[4],0,0,7); ctx.fill(); });
  ctx.fillStyle='#14100c'; ctx.fillRect(x0+Lh*0.16, crown+10, 22, 30);        // дыры от панелей
  ctx.fillStyle='#14100c'; ctx.fillRect(x1-Lh*0.2, shoulder-6, 16, 22);
  ctx.restore();
}
// ════════ СТАРТ — одиночный красный флажок (на линии старта байка) ════════
const START_X = ()=> W - 90;                // мировой X флажка на старте: ближе к правому краю, но не вплотную
function drawBaseA(){
  const sxw = START_X();
  const fx = sxw - scroll;                   // экранный X (мир − скролл, как финиш)
  if(fx<-40||fx>W+40) return;
  const gy = terrY(sxw);
  // узкий длинный красный флажок: тонкий шест + вытянутый треугольный вымпел
  ctx.strokeStyle='#cfcfcf';ctx.lineWidth=2;ctx.lineCap='round';
  ctx.beginPath();ctx.moveTo(fx,gy);ctx.lineTo(fx,gy-92);ctx.stroke();ctx.lineCap='butt'; // шест
  ctx.fillStyle='#7a7a7a';ctx.beginPath();ctx.arc(fx,gy-92,2.4,0,7);ctx.fill();           // навершие
  ctx.fillStyle='#e23c3c';                  // вымпел
  ctx.beginPath();ctx.moveTo(fx+1,gy-92);ctx.lineTo(fx+30,gy-84);ctx.lineTo(fx+1,gy-76);ctx.closePath();ctx.fill();
  ctx.fillStyle='rgba(255,255,255,0.18)';   // блик
  ctx.beginPath();ctx.moveTo(fx+1,gy-92);ctx.lineTo(fx+16,gy-88.5);ctx.lineTo(fx+1,gy-85);ctx.closePath();ctx.fill();
}

function landingPuff(x,y,power){
  const n=6+Math.floor(power*12);
  for(let i=0;i<n;i++){
    if(Math.random()<0.6) parts.push({k:'d',x:x+rand(-12,12),y:y-4,vx:rand(-70,70),vy:rand(-130,-30),life:0,max:rand(0.5,0.95),size:rand(6,13)});
    else parts.push({k:'r',x:x+rand(-7,7),y:y-3,vx:rand(-180,180),vy:rand(-280,-90),life:0,max:rand(0.4,0.7),size:rand(2,4.2),col:Math.random()<0.5?'#4a3018':'#5a4226'});
  }
}
// ════════ ЧАСТИЦЫ ИЗ-ПОД КОЛЕСА ════════
function spawnSlip(p,dt){
  if(slip<2)return;
  emit+=slip*dt*3.4;                        // намного гуще
  const cxr=p.rear.x, cyr=p.gR;             // контакт заднего колеса с землёй
  while(emit>=1 && parts.length<700){ emit--;
    if(Math.random()<0.6){ // камень — мощный выброс ВВЕРХ из-под колеса
      parts.push({k:'r',x:cxr+rand(-5,3),y:cyr-9,vx:rand(-250,-30),vy:rand(-600,-320),life:0,max:rand(0.55,1.0),size:rand(2.2,4.8),col:Math.random()<0.5?'#4a3018':'#5a4226'});
    } else { // пыль — плотное облако, поднимается
      parts.push({k:'d',x:cxr+rand(-9,4),y:cyr-8,vx:rand(-100,-10),vy:rand(-280,-90),life:0,max:rand(0.6,1.1),size:rand(6,14)});
    }
  }
}
function updateDrawEjected(dt){
  if(!ejected) return;
  const o=ejected;
  o.life-=dt;
  if(o.life<=0){ ejected=null; return; }                 // исчезает (назад не возвращаемся)
  o.vy+=900*dt;                                          // гравитация
  o.x+=(o.vx-speed)*dt;                                  // мир уезжает влево на скорость байка
  o.y+=o.vy*dt;
  const gy=terrY(scroll+o.x)-7;                          // уровень лёжа на земле (радиус баллона)
  if(o.y>=gy){                                           // касание земли → катится
    o.y=gy;
    if(!o.landed){ o.landed=true; o.vy*=-0.35; o.vrot=o.vx*0.05; }  // первый отскок
    else { o.vy*=-0.25; }
    o.vx*=0.86;                                          // трение качения
    if(Math.abs(o.vy)<40) o.vy=0;
  }
  o.rot+=o.vrot*dt; o.vrot*=0.98;
  // фейд в конце жизни
  const al = o.life<0.6 ? o.life/0.6 : 1;
  // отрисовка баллона (тот же стиль, что в клетке)
  ctx.save();ctx.globalAlpha=al;ctx.translate(o.x,o.y);ctx.rotate(o.rot);
  const L=31,R=7.4;
  ctx.fillStyle='#827d74';ctx.beginPath();ctx.roundRect(-L/2,-R,L,R*2,R);ctx.fill();
  ctx.fillStyle='rgba(58,42,28,0.28)';ctx.beginPath();ctx.roundRect(-L/2,0,L,R,R*0.7);ctx.fill();
  ctx.fillStyle='rgba(0,0,0,0.22)';ctx.beginPath();ctx.roundRect(-L/2,R*0.45,L,R*0.55,R*0.5);ctx.fill();
  ctx.fillStyle='#6e6960';ctx.beginPath();ctx.ellipse(-L/2+2,0,2,R*0.9,0,0,7);ctx.fill();
  const nx=L*0.28;
  ctx.fillStyle='#56524b';ctx.fillRect(nx-1.6,-R-3.5,3.2,4);
  ctx.fillStyle='#6a5230';ctx.fillRect(nx-2.8,-R-5.8,5.6,2.6);
  ctx.restore();
}
function updateDrawParts(dt){
  for(let i=parts.length-1;i>=0;i--){const o=parts[i];
    o.life+=dt; if(o.life>=o.max){parts.splice(i,1);continue;}
    o.vy+=820*dt;                          // гравитация
    o.x+=(o.vx-speed)*dt;                  // мир уезжает влево на скорость байка
    o.y+=o.vy*dt;
    if(o.k==='r' && o.vy>0 && o.y>terrY(scroll+o.x)){ parts.splice(i,1); continue; }
    const t=o.life/o.max;
    if(o.k==='r'){
      ctx.fillStyle=o.col;ctx.globalAlpha=1-t*0.45;
      const s=o.size*(1-t*0.18);
      ctx.fillRect(o.x-s/2,o.y-s/2,s,s);
    } else {
      ctx.fillStyle='#9a7a4a';ctx.globalAlpha=0.40*(1-t);
      ctx.beginPath();ctx.arc(o.x,o.y,o.size*(1+t*1.8),0,7);ctx.fill();
    }
  }
  ctx.globalAlpha=1;
}

// ════════ ЦИКЛ + КАМЕРА ════════
let camY=null,last=performance.now();
function loop(now){
  const dt=Math.min((now-last)/1000,0.033);last=now;
  const p=updatePhysics(dt);
  // ── УРОВЕНЬ: таймер тикает в заезде; финиш Б / провал по грузу ──
  if(gameState==='RIDING'){
    rideTime+=dt;
    if(scroll+CX()>=GOAL){ gameState='ARRIVING'; arriveT=0; }               // доехал до Б — глушим газ, едем накатом
    else if(cargo===0 || rideTime>=timeLimit){ finishLevel('FAILED'); }     // груз разбит ИЛИ время вышло
  } else if(gameState==='ARRIVING'){
    arriveT+=dt;                                                            // двигатель заглушён (eng=false вне RIDING)
    if(arriveT>=FINISH_PAUSE) finishLevel('DELIVERED');                     // короткая пауза у ангара → плашка
  }
  const targetCam=p.cy-H*0.52;
  if(camY===null)camY=targetCam;
  camY+=(targetCam-camY)*Math.min(1,7*dt);
  ctx.clearRect(0,0,W,H);drawSky();
  ctx.save();ctx.translate(0,-camY);
  drawGround();
  spawnSlip(p,dt); updateDrawParts(dt);     // камни/пыль под задним колесом
  drawBike(p);
  updateDrawEjected(dt);                    // вылетевший баллон (летит/катится по рельефу)
  ctx.restore();
  drawCargoHUD();                            // индикатор баллонов в левом верхнем углу
  drawTimerClock();                          // аналоговый таймер (справа вверху)
  drawSpeedo();                              // спидометр (внизу по центру)
  requestAnimationFrame(loop);
}
// ── HUD: столько баллонов, сколько в клетке; у каждого своя шкала урона ──
function drawCargoHUD(){
  const bw=26, bh=60, x0=16, y=28, gap=10;   // y=28 → центр тела (y+30=58) совпадает с центром циферблата
  const TH=DEPRESS_TH;   // красная линия = порог разгерметизации (единый с подсчётом на финише)
  for(let idx=0; idx<CARGO_MAX; idx++){
    const x=x0+idx*(bw+gap), lineY=y+bh-bh*TH;
    const tk=tanks[idx];                       // живой баллон в этом слоте, либо undefined (вылетел)
    ctx.save();ctx.textAlign='center';
    if(!tk){
      // ── ВЫЛЕТЕВШИЙ баллон: неактивный слот (чуть насыщеннее, alpha 0.50) ──
      ctx.globalAlpha=0.50;
      ctx.fillStyle='rgba(15,10,5,0.55)';
      ctx.beginPath();ctx.roundRect(x,y,bw,bh,6);ctx.fill();
      ctx.strokeStyle='rgba(150,140,120,0.7)';ctx.lineWidth=1.8;
      ctx.beginPath();ctx.roundRect(x,y,bw,bh,6);ctx.stroke();
      ctx.fillStyle='rgba(150,140,120,0.7)';ctx.fillRect(x+bw/2-2.5,y-5,5,5);
      ctx.fillStyle='rgba(220,210,195,0.9)';ctx.font='bold 13px sans-serif';
      ctx.fillText('—', x+bw/2, y+bh+16);
      ctx.restore();ctx.textAlign='left';
      continue;
    }
    const w=tk.w, pct=Math.round(w*100), danger=w>=TH;
    ctx.fillStyle='rgba(15,10,5,0.55)';
    ctx.beginPath();ctx.roundRect(x,y,bw,bh,6);ctx.fill();
    ctx.save();ctx.beginPath();ctx.roundRect(x,y,bw,bh,6);ctx.clip();   // обрезка по форме
    if(!danger){
      const fillH=bh*w, k=Math.min(1,w/TH);
      const r=224+Math.round(18*k), g=Math.round(206-66*k), b=Math.round(150-60*k);
      ctx.fillStyle=`rgb(${r},${g},${b})`;ctx.fillRect(x,y+bh-fillH,bw,fillH);
    } else {
      const segH=bh*TH, fillH=segH*Math.min(1,(w-TH)/(1-TH));
      const pulse=0.6+0.4*Math.abs(Math.sin(tSec*16));
      ctx.fillStyle=`rgba(235,50,45,${pulse})`;ctx.fillRect(x,lineY-fillH,bw,fillH);
    }
    ctx.restore();
    ctx.strokeStyle='rgba(251,146,60,0.7)';ctx.lineWidth=1.8;
    ctx.beginPath();ctx.roundRect(x,y,bw,bh,6);ctx.stroke();
    ctx.fillStyle='rgba(251,146,60,0.7)';ctx.fillRect(x+bw/2-2.5,y-5,5,5);  // пиптик
    ctx.fillStyle=danger?'#ff6a5a':'rgba(245,230,205,0.95)';ctx.font='bold 13px sans-serif';
    ctx.fillText(pct+'%', x+bw/2, y+bh+16);
    ctx.restore();ctx.textAlign='left';
  }
}
// ── АНАЛОГОВЫЙ ТАЙМЕР: деления + одна красная стрелка (1 оборот = весь лимит) ──
// скорость стрелки зависит от timeLimit: короткий лимит → быстрый оборот.
// ── СПИДОМЕТР под референс (Earn to Die): круговая шкала 270° с цифрами 0..120, стрелка, без числа в центре ──
// Верх шкалы (120) = максимум байка (SPD_MAX=760 px/с). Внизу по центру.
function drawSpeedo(){
  const R=78, cx=W*0.5, cy=H-64;
  const a0=0.75*Math.PI, SWEEP=1.5*Math.PI;                    // 270°, разрыв снизу: 0 слева-внизу → 120 справа-внизу
  const disp=Math.abs(speed)/SPD_MAX*120;                      // 0..120 (км/ч-условно)
  const ah=a0 + Math.max(0,Math.min(1,disp/120))*SWEEP;        // угол стрелки
  ctx.save(); ctx.textAlign='center'; ctx.textBaseline='middle';
  // корпус: тёмный фактурный циферблат + двойной кант
  const fg=ctx.createRadialGradient(cx-R*0.2,cy-R*0.2,R*0.15, cx,cy,R+6);
  fg.addColorStop(0,'#2a1d14'); fg.addColorStop(0.72,'#1b120c'); fg.addColorStop(1,'#100b07');
  ctx.fillStyle=fg; ctx.beginPath(); ctx.arc(cx,cy,R+7,0,7); ctx.fill();
  ctx.strokeStyle='rgba(45,33,24,0.95)'; ctx.lineWidth=5; ctx.beginPath(); ctx.arc(cx,cy,R+5,0,7); ctx.stroke();
  ctx.strokeStyle='rgba(251,146,60,0.30)'; ctx.lineWidth=1.6; ctx.beginPath(); ctx.arc(cx,cy,R+8,0,7); ctx.stroke();
  // деления 0..120 (шаг 5), крупные на каждые 20
  for(let val=0; val<=120; val+=5){
    const a=a0+(val/120)*SWEEP, major=(val%20===0), r2=R-(major?15:8);
    ctx.strokeStyle=major?'rgba(238,224,196,0.92)':'rgba(238,224,196,0.45)';
    ctx.lineWidth=major?2.8:1.2;
    ctx.beginPath(); ctx.moveTo(cx+Math.cos(a)*R, cy+Math.sin(a)*R);
                     ctx.lineTo(cx+Math.cos(a)*r2, cy+Math.sin(a)*r2); ctx.stroke();
  }
  // цифры на каждые 20
  ctx.fillStyle='rgba(238,224,196,0.95)'; ctx.font='bold 13px sans-serif';
  for(let val=0; val<=120; val+=20){
    const a=a0+(val/120)*SWEEP;
    ctx.fillText(val, cx+Math.cos(a)*R*0.66, cy+Math.sin(a)*R*0.66);
  }
  // подпись единиц (как 'mph' на референсе) — над ступицей
  ctx.fillStyle='rgba(238,224,196,0.6)'; ctx.font='bold 11px sans-serif';
  ctx.fillText('km/h', cx, cy-R*0.34);
  // стрелка (оранжевая, с коротким хвостом)
  ctx.strokeStyle='#ff6a3c'; ctx.lineWidth=3.6; ctx.lineCap='round';
  ctx.beginPath(); ctx.moveTo(cx-Math.cos(ah)*R*0.18, cy-Math.sin(ah)*R*0.18);
                   ctx.lineTo(cx+Math.cos(ah)*R*0.80, cy+Math.sin(ah)*R*0.80); ctx.stroke();
  ctx.lineCap='butt';
  // ступица
  ctx.fillStyle='#2a1d12'; ctx.beginPath(); ctx.arc(cx,cy,6.5,0,7); ctx.fill();
  ctx.strokeStyle='#fb923c'; ctx.lineWidth=2; ctx.beginPath(); ctx.arc(cx,cy,6.5,0,7); ctx.stroke();
  ctx.restore();
}
function drawTimerClock(){
  const R=40, cx=W-56, cy=58;
  const prog=Math.max(0, Math.min(1, timeLimit>0 ? rideTime/timeLimit : 0));  // доля пройденного времени
  const tleft=Math.max(0, timeLimit-rideTime), low=tleft<8;                   // тревога на последних секундах
  const a0=-Math.PI/2, ah=a0+prog*Math.PI*2;                                  // 12ч → по часовой
  ctx.save(); ctx.textAlign='center'; ctx.textBaseline='middle';
  // циферблат: тёмная подложка + оранжевый кант
  ctx.fillStyle='rgba(15,10,5,0.55)'; ctx.beginPath(); ctx.arc(cx,cy,R+6,0,7); ctx.fill();
  ctx.strokeStyle='rgba(251,146,60,0.32)'; ctx.lineWidth=1.5; ctx.beginPath(); ctx.arc(cx,cy,R+6,0,7); ctx.stroke();
  // заметаемый стрелкой сектор (пройденное время); на финише пульсирует красным
  ctx.fillStyle = low ? `rgba(235,70,55,${0.28+0.26*Math.abs(Math.sin(tSec*8))})` : 'rgba(120,180,232,0.42)';
  ctx.beginPath(); ctx.moveTo(cx,cy); ctx.arc(cx,cy,R-2,a0,ah); ctx.closePath(); ctx.fill();
  // 60 делений: каждое 5-е — крупное
  for(let i=0;i<60;i++){
    const a=a0+i/60*Math.PI*2, major=(i%5===0), r2=R-(major?9:5);
    ctx.strokeStyle = major?'rgba(232,213,176,0.85)':'rgba(232,213,176,0.36)';
    ctx.lineWidth   = major?2.4:1;
    ctx.beginPath(); ctx.moveTo(cx+Math.cos(a)*R, cy+Math.sin(a)*R);
                     ctx.lineTo(cx+Math.cos(a)*r2, cy+Math.sin(a)*r2); ctx.stroke();
  }
  // красная стрелка с коротким хвостом
  ctx.strokeStyle = low?'#ff3a2a':'#ff5a3c'; ctx.lineWidth=3; ctx.lineCap='round';
  ctx.beginPath(); ctx.moveTo(cx-Math.cos(ah)*R*0.16, cy-Math.sin(ah)*R*0.16);
                   ctx.lineTo(cx+Math.cos(ah)*R*0.82, cy+Math.sin(ah)*R*0.82); ctx.stroke();
  ctx.lineCap='butt';
  // ступица
  ctx.fillStyle='#1a120a'; ctx.beginPath(); ctx.arc(cx,cy,4.4,0,7); ctx.fill();
  ctx.strokeStyle=low?'#ff5a3c':'#fb923c'; ctx.lineWidth=1.8; ctx.beginPath(); ctx.arc(cx,cy,4.4,0,7); ctx.stroke();
  // статичный лимит времени под циферблатом (целые секунды, не тикает)
  ctx.fillStyle='rgba(232,213,176,0.9)'; ctx.font='bold 13px sans-serif';
  ctx.fillText(timeLimit+' с', cx, cy+R+15);
  ctx.restore();
}

// ════════ УПРАВЛЕНИЕ: GAS — держать=газ, короткий тап=прыжок ════════
const gas=document.getElementById('gas');
const TAP_MS=200;
let pressT=0, pressed=false, speedAtDown=0;
function down(){ if(pressed)return; pressed=true; gasHeld=true; pressT=performance.now(); speedAtDown=speed; gas.classList.add('pressed');
  if(gameState==='READY') startRide();              // первый зажим газа = старт заезда
}
function up(){ if(!pressed)return; pressed=false; gasHeld=false; gas.classList.remove('pressed');
  // короткое нажатие + байк уже ехал = прыжок (с места не прыгаем), только во время заезда
  if(gameState==='RIDING' && performance.now()-pressT < TAP_MS && speedAtDown > JUMP_MIN_SPD) jump();
}
['touchstart','mousedown'].forEach(e=>gas.addEventListener(e,ev=>{ev.preventDefault();down();},{passive:false}));
['touchend','touchcancel','mouseup','mouseleave'].forEach(e=>gas.addEventListener(e,ev=>{ev.preventDefault();up();},{passive:false}));
window.addEventListener('keydown',e=>{if((e.code==='Space'||e.code==='ArrowRight')&&!e.repeat)down();});
window.addEventListener('keyup',e=>{if(e.code==='Space'||e.code==='ArrowRight')up();});
const bT=document.getElementById('btn-terr'),bR=document.getElementById('btn-regen');
const TERR_INFO={PLAIN:{label:'РАВНИНА',cls:'t-plain'},HILLS:{label:'ХОЛМЫ',cls:'t-hills'},CLIFFS:{label:'СКАЛЫ-ОБРЫВЫ',cls:'t-cliffs'}};
const TERR_ORDER=['PLAIN','HILLS','CLIFFS'];
function applyTerrUI(){
  const info=TERR_INFO[TERR_MODE];
  bT.textContent='РЕЛЬЕФ: '+info.label;
  bT.classList.remove('t-plain','t-hills','t-cliffs');bT.classList.add(info.cls);
}
bT.onclick=()=>{ TERR_MODE=TERR_ORDER[(TERR_ORDER.indexOf(TERR_MODE)+1)%3]; applyTerrUI(); resetRide(); };
bR.onclick=()=>resetRide();
const bP=document.getElementById('btn-pack');   // кнопка укладки скрыта (раскладка теперь по количеству)
const bC=document.getElementById('btn-cage');
bC.onclick=()=>{ cageW=(cageW+1)%CAGE_STEPS.length; bC.textContent='ПРУТЬЯ: '+CAGE_LABEL[cageW]; };
document.getElementById('btn-reset').onclick=()=>resetRide();   // полный сброс: заезд+баллоны+позиция
document.getElementById('res-restart').onclick=()=>resetRide(); // кнопка на экране результата
applyTerrUI();
window.addEventListener('resize',resize);
resize();requestAnimationFrame(loop);
</script>
