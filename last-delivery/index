// ════════ ФОН + ЗЕМЛЯ ════════
function drawSky(){
  const g=ctx.createLinearGradient(0,0,0,H);
  g.addColorStop(0,'#3a3250');g.addColorStop(0.45,'#6a4a52');
  g.addColorStop(0.7,'#c66a32');g.addColorStop(1,'#e8a040');
  ctx.fillStyle=g;ctx.fillRect(0,0,W,H);
}
function drawGround(){
  const BOT=8000;
  const pts=[];for(let sx=-STEP;sx<=W+STEP;sx+=STEP)pts.push({x:sx,y:terrY(scroll+sx)});
  ctx.beginPath();ctx.moveTo(pts[0].x,pts[0].y);pts.forEach(p=>ctx.lineTo(p.x,p.y));
  ctx.lineTo(W,BOT);ctx.lineTo(0,BOT);ctx.closePath();ctx.fillStyle='#6e4a22';ctx.fill();
  ctx.beginPath();ctx.moveTo(pts[0].x,pts[0].y+18);pts.forEach(p=>ctx.lineTo(p.x,p.y+18));
  ctx.lineTo(W,BOT);ctx.lineTo(0,BOT);ctx.closePath();ctx.fillStyle='#3a2614';ctx.fill();
  ctx.beginPath();ctx.moveTo(pts[0].x,pts[0].y);pts.forEach(p=>ctx.lineTo(p.x,p.y));
  ctx.lineWidth=4;ctx.strokeStyle='#8a5a2a';ctx.stroke();
  ctx.beginPath();ctx.moveTo(pts[0].x,pts[0].y);pts.forEach(p=>ctx.lineTo(p.x,p.y));
  ctx.lineWidth=1.5;ctx.strokeStyle='rgba(255,150,40,0.5)';ctx.stroke();
  drawPitFloor();// камни на дне ям
  drawRamps();   // трамплины (земляные насыпи)
  drawBaseA();   // флажок старта A
  drawHangar();  // заброшенный ангар на финишной прямой
}
// ── КАМНИ НА ДНЕ ЯМЫ ──
function drawPitFloor(){
  for(const p of pits){
    if(p.fx0===undefined) continue;
    const a=p.fx0-scroll, b=p.fx1-scroll;
    if(b<-30 || a>W+30) continue;
    const fy=terrY((p.fx0+p.fx1)/2);                       // y плоского дна
    const rocks=[[0.12,8],[0.27,12],[0.42,7],[0.55,13],[0.68,8],[0.82,10],[0.20,5],[0.61,6],[0.90,7],[0.35,5]];
    for(const [t,rad] of rocks){
