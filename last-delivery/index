function drawWheel(x,y,ang,spin){
  // spin — модуль угловой скорости (рад/с). Высокая → motion blur вместо чётких спиц.
  const blur=Math.min(1,Math.max(0,(Math.abs(spin)-7)/13));    // тает раньше: полный блюр уже к ~20 рад/с
  ctx.save();ctx.translate(x,y);
  // покрышка
  ctx.beginPath();ctx.arc(0,0,WR,0,7);ctx.lineWidth=8;ctx.strokeStyle='#181818';ctx.stroke();
  // грунтозацепы — чёткие на низкой скорости, тают в кольцо при блюре
  ctx.save();ctx.rotate(ang);ctx.strokeStyle='#0c0c0c';ctx.lineWidth=3;ctx.lineCap='round';
  ctx.globalAlpha=1-blur;
  for(let i=0;i<12;i++){const an=i/12*Math.PI*2;
    ctx.beginPath();ctx.moveTo(Math.cos(an)*(WR+1),Math.sin(an)*(WR+1));
    ctx.lineTo(Math.cos(an)*(WR+4),Math.sin(an)*(WR+4));ctx.stroke();}
  ctx.globalAlpha=1;ctx.lineCap='butt';ctx.restore();
  if(blur>0){ // смазанное кольцо протектора
    ctx.beginPath();ctx.arc(0,0,WR+2.5,0,7);ctx.lineWidth=3;ctx.strokeStyle='#0c0c0c';ctx.globalAlpha=blur*0.7;ctx.stroke();ctx.globalAlpha=1;
  }
  // обод
  ctx.beginPath();ctx.arc(0,0,WR*0.52,0,7);ctx.lineWidth=2.5;ctx.strokeStyle='#9c6234';ctx.stroke();
  // спицы — чёткие, либо размытый веер
  if(blur<1){
    ctx.save();ctx.rotate(ang);ctx.strokeStyle='#6a655a';ctx.lineWidth=1.3;ctx.globalAlpha=1-blur;
    for(let s=0;s<8;s++){const an=s/8*Math.PI*2;ctx.beginPath();ctx.moveTo(0,0);ctx.lineTo(Math.cos(an)*(WR*0.5-1),Math.sin(an)*(WR*0.5-1));ctx.stroke();}
    ctx.globalAlpha=1;ctx.restore();
  }
  if(blur>0){ // радиальные размытые дуги (motion blur спиц)
    ctx.save();ctx.rotate(ang);ctx.strokeStyle='#6a655a';ctx.globalAlpha=blur*0.5;ctx.lineWidth=1.1;
    for(let s=0;s<8;s++){const a0=s/8*Math.PI*2;ctx.beginPath();ctx.arc(0,0,WR*0.34,a0,a0+0.7);ctx.stroke();}
    ctx.globalAlpha=1;ctx.restore();
  }
  ctx.fillStyle='#2a2620';ctx.beginPath();ctx.arc(0,0,3.2,0,7);ctx.fill();
  ctx.restore();
}
function spring(a,b,col){
  const dx=b.x-a.x,dy=b.y-a.y,len=Math.hypot(dx,dy)||1,px=-dy/len,py=dx/len,coils=6,amp=3.2;
  ctx.strokeStyle=col;ctx.lineWidth=2.4;ctx.lineCap='round';ctx.beginPath();ctx.moveTo(a.x,a.y);
  for(let i=0;i<=coils;i++){const t=i/coils,x=a.x+dx*t,y=a.y+dy*t,s=(i%2?1:-1)*amp;ctx.lineTo(x+px*s,y+py*s);}
  ctx.lineTo(b.x,b.y);ctx.stroke();ctx.lineCap='butt';
}
function fork(t,b){
