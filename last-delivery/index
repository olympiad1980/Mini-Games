// ── ПОЛНАЯ ФИГУРА на байке (локальные коорд. drawFrame; точки байка фиксированы) ──
function drawRider(){
  const P=riderPose, lean=P.lean, K=1.40;     // K — фигура взрослого относительно байка
  const standN=Math.max(0,Math.min(1, P.stand/6.5));        // 0 сидит → 1 стоит на ногах
  const hip={x:-37 + 15*standN, y:-34 - 11*standN + P.hop}; // отодвинут ВЛЕВО; в полёте встаёт во весь рост (ноги почти прямые)
  const SHOW_ARM=true;    // рука включена (анатомия по референсу)
  ctx.save();
