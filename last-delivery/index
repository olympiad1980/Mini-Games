const parts=[]; let emit=0;
const rand=(a,b)=>a+Math.random()*(b-a);
function rigidSolve(cx,seedA){
  let a=seedA||0;
  for(let it=0;it<4;it++){
    const rx=cx-HALF*Math.cos(a),fx=cx+HALF*Math.cos(a);
    a=Math.atan2(terrY(scroll+fx)-terrY(scroll+rx),fx-rx);
  }
  const rx=cx-HALF*Math.cos(a),fx=cx+HALF*Math.cos(a);
  const gR=terrY(scroll+rx),gF=terrY(scroll+fx);
  const axleY=Math.min(gR-WR+HALF*Math.sin(a),gF-WR-HALF*Math.sin(a));
  return {a,axleY,gR,gF,rx,fx};
}
function updatePhysics(dt){
  const cx=CX();
  const s=rigidSolve(cx,bike.ang);     // как байк стоял бы на земле сейчас
  const groundAxleY=s.axleY, groundAng=s.a;
  if(!bike.init){bike.axleY=groundAxleY;bike.ang=groundAng;bike.init=true;}

  const spd0=speed;                              // скорость в начале кадра (для детекта момента старта)
  // ── продольная физика (только на земле) ──
  const eng = gasHeld && gameState==='RIDING';   // газ работает только во время заезда
  if(!bike.airborne){
    if(eng){
      const lowGear = 1 + 0.9*Math.max(0, 1 - Math.abs(speed)/150); // тяга на низах (1-я передача): сильнее — байк ощутимо борется с подъёмом
      speed += ENG*lowGear*dt;                           // двигатель
    }
    speed += GRAV_ROLL*Math.sin(groundAng)*dt;         // скатывание по склону (вниз +, вверх −)
    speed -= speed*DRAG*dt;                            // сопротивление качению (плавно к 0)
    speed = Math.max(SPD_MIN, Math.min(SPD_MAX, speed));
    // ── гашение при выполаживании после КРУТОГО спуска: импульс перенаправляется на ровное, часть теряется ──
    if(prevGroundAng > LEVEL_MIN && groundAng < prevGroundAng){
      const dDown = prevGroundAng - groundAng;             // насколько выположило за кадр
      speed -= speed * Math.min(0.5, dDown * LEVEL_LOSS);  // тем сильнее, чем круче был спуск и резче выход
    }
    if(!eng && Math.abs(speed)<6 && Math.abs(Math.sin(groundAng))<0.03) speed=0; // покой на ровном
  }
  // ── пробуксовка заднего колеса: старт с низкой скорости + крутой подъём ──
  let slipRate=0;
  if(!bike.airborne && eng && speed>-5){
    const launch=Math.max(0,1-Math.abs(speed)/LAUNCH_SPD);                        // трогание с места / после остановки
    const steep =Math.max(0,(-Math.sin(groundAng)-SLIP_THRESH)/(1-SLIP_THRESH));  // крутой/затяжной подъём
    slipRate=SLIP_GAIN*Math.min(1.5, launch*0.9 + steep);
  }
  slip+=(slipRate-slip)*Math.min(1,12*dt);   // сглаживание
  // ── СТАРТ-ВИЛЛИ: ТОЛЬКО при трогании с места (скорость пересекает порог снизу под газом). Во время езды не срабатывает. ──
  if(!startMoved && eng && !bike.airborne && spd0<12 && speed>=12){ launchWheelie=1; startMoved=true; }  // старт-вилли ТОЛЬКО при первом трогании уровня; в заезде (в т.ч. со дна V в гору) не появляется
  launchWheelie = Math.max(0, launchWheelie - dt*1.4);                 // импульс затухает ~0.7с
  const wTarget = bike.airborne ? 0 : WHEELIE_MAX*launchWheelie;       // нос вверх только на старте
  wheelie+=(wTarget-wheelie)*Math.min(1,8*dt);
  scroll += speed*dt;
  spinF = speed/WR;                          // угловая скорость переднего (рад/с)
  spinR = speed/WR + slip;                   // заднего + букс
  wheelAngF += spinF*dt;                     // переднее — катится по скорости
  wheelAngR += spinR*dt;                     // заднее — + проскальзывание

  // ── ТРАМПЛИН: отрыв ТОЛЬКО при пересечении гребня рампы и только на скорости ──
  if(!bike.airborne && nextRamp<ramps.length && (scroll+cx) >= ramps[nextRamp].x){
    const r=ramps[nextRamp];
    if(r.type==='rubble'){
      bike.airborne=true;                                                   // БЕЗ ПОДБРОСА: чистый отрыв от кромки (vy не трогаем) → просто падаешь в яму, без «прыжка» вверх
    } else if(speed>RAMP_MIN){ bike.airborne=true;
      bike.vy = -(RAMP_BASE + speed*r.slope*RAMP_K);                       // трамплины: база + ∝ скорость×крутизна
    }
    nextRamp++;                                                                // рампа пройдена (даже если медленно — просто переехал)
  }

  // ── вертикаль: на земле байк ПЛОТНО следует рельефу; в полёте — только после ручного прыжка ──
