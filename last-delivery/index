  const fix=(rx,ry)=>({x:hip.x+(rx-hip.x)/K, y:hip.y+(ry-hip.y)/K});
  const grip=fix(9,-49);
  // СТОПА: при подскоке подхватывается вверх (колено держит сгиб); угол стопы статичный (носок вверх)
  let peg=fix(-1,7);
  if(P.hop){
    peg={x:peg.x, y:peg.y + P.hop*0.65};                 // стопа едет за подскоком на 65%
    const dx=peg.x-hip.x, dy=peg.y-hip.y, d=Math.hypot(dx,dy), legMax=41.5; // не разгибать колено дальше ~150°
    if(d>legMax){ peg={x:hip.x+dx/d*legMax, y:hip.y+dy/d*legMax}; }
