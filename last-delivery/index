function ik2(ax,ay,tx,ty,l1,l2,bend){       // 2-звенная IK: сустав между опорой и целью, длины сегментов постоянны
  let dx=tx-ax, dy=ty-ay, d=Math.hypot(dx,dy)||0.001;
  d=Math.min(d,(l1+l2)*0.999); d=Math.max(d,Math.abs(l1-l2)+0.001);
  const a=(d*d+l1*l1-l2*l2)/(2*d), h=Math.sqrt(Math.max(0,l1*l1-a*a));
  const ux=dx/d, uy=dy/d;
  return {x:ax+ux*a - uy*h*bend, y:ay+uy*a + ux*h*bend};
}
