  ctx.beginPath();ctx.moveTo(13,-4);ctx.lineTo(pivot.x,pivot.y);ctx.stroke();      // нижний рейл
  ctx.beginPath();ctx.moveTo(2,-33);ctx.lineTo(-34,-30);ctx.stroke();             // подрама
  ctx.beginPath();ctx.moveTo(-10,-31);ctx.lineTo(pivot.x,pivot.y);ctx.stroke();    // косынка к шарниру
  ctx.beginPath();ctx.moveTo(2,-33);ctx.lineTo(8,-6);ctx.stroke();                // средняя стойка

  // ── двигатель (одноцилиндровый thumper) ──
  ctx.fillStyle=RUST.engine;ctx.beginPath();ctx.roundRect(-6,-16,24,18,3);ctx.fill();
  ctx.fillStyle=RUST.engineDk;for(let i=0;i<5;i++)ctx.fillRect(0+i*4,-22,2.4,8); // рёбра головки
  ctx.fillStyle=RUST.engineDk;ctx.beginPath();ctx.roundRect(2,-24,12,4,2);ctx.fill();
