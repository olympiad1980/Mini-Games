    const RTfixS=[-80+CAGE_DX,-55+rearSag];              // задне-верх перегородок с просадкой (поднят, сдвинут)
    // нижний горизонтальный прут длиннее низа на 12% (выступает назад), зад просел
    const RBlong=[FB[0]+(RB[0]-FB[0])*1.12, RB[1]+rearSag];

    ctx.lineCap='round';ctx.lineJoin='round';

    // ── v2: ВЕРТИКАЛЬНЫЕ баллоны O₂; качание + подскок + резиновая деформация при ударе ──
    const topIdx=topTankIdx();
    const drawTank=(bxT,byT,baseLean,i)=>{
      const tk=tanks[i];
      const ph=tk?tk.ph:0, fr=tk?tk.fr:16;
      const lift = -(tk?tk.hop:0);                              // одиночный подскок этого баллона (вверх)
      // качание: базовый крен + лёгкая раскачка от своего подскока + крен на спуске
      const swayLand = (tk?tk.hop:0)*0.006*Math.sin(ph*2.0);
      const swaySlope= slopeShake*Math.sin(tSec*fr+ph)*0.10;
      const ang = baseLean + swayLand + swaySlope;
      // мелкая ДРОЖЬ на опасном спуске (вразнобой)
      const dj = slopeShake*1.4;
      const jx = Math.sin(tSec*fr+ph)*dj;
      const jy = Math.cos(tSec*fr*1.27+ph)*dj*0.6;
      ctx.save();
      ctx.translate(bxT+jx, byT+lift+jy);                       // основание баллона
      ctx.rotate(ang);                                          // крен вокруг основания (жёсткий, без деформации)
      ctx.scale(1.08,1.08);                                      // размер баллона (+8% к исходному)
      const TR=6.7, TH=23, NR=2.3;                              // радиус тела, высота тела, радиус горла
      // ── тело: СИММЕТРИЧНАЯ капсула — верх и низ скруглены одинаково (радиус TR) ──
      ctx.fillStyle='#828079';ctx.beginPath();ctx.roundRect(-TR,-TH,TR*2,TH,TR);ctx.fill();
      // детали поверхности — в КЛИПЕ по телу, чтобы не вылезали за капсулу
      ctx.save();
      ctx.beginPath();ctx.roundRect(-TR,-TH,TR*2,TH,TR);ctx.clip();
      ctx.fillStyle='rgba(120,140,150,0.16)';ctx.beginPath();ctx.ellipse(-TR*0.3,-TH*0.62,TR*0.55,TH*0.26,0.3,0,7);ctx.fill();
      ctx.fillStyle='rgba(150,120,70,0.14)';ctx.beginPath();ctx.ellipse(TR*0.25,-TH*0.34,TR*0.5,TH*0.2,-0.2,0,7);ctx.fill();
      ctx.fillStyle='rgba(58,42,28,0.30)';ctx.beginPath();ctx.roundRect(-TR,-TH*0.30,TR*2,TH*0.30,[0,0,TR,TR]);ctx.fill();   // грязь по низу
      ctx.fillStyle='rgba(0,0,0,0.20)';ctx.fillRect(TR*0.38,-TH,TR*0.62,TH);                                              // боковая тень
      ctx.fillStyle='rgba(225,238,242,0.20)';ctx.fillRect(-TR+1.5,-TH+TR*0.8,1.9,TH-TR*1.6);                              // блик
      ctx.restore();
      // ── горло + вентиль на ВЕРХНЕМ скруглении; клапан ОТЗЕРКАЛЕН (маховик слева) ──
      ctx.fillStyle='#5a564e';ctx.fillRect(-NR,-TH-4,NR*2,5);                                  // горло на куполе
      ctx.fillStyle='#6f6a61';ctx.beginPath();ctx.roundRect(-NR-1,-TH-7,NR*2+2,3.4,1.2);ctx.fill();  // блок вентиля
      ctx.fillStyle='#6a5230';ctx.beginPath();ctx.arc(-(NR+1.2),-TH-5.3,1.8,0,7);ctx.fill();          // латунный маховик слева
      ctx.fillStyle='#3a2c18';ctx.beginPath();ctx.arc(-(NR+1.2),-TH-5.3,0.7,0,7);ctx.fill();
      ctx.restore();
    };
    // рисуем РОВНО столько баллонов, сколько в грузе (layoutNow по количеству)
    const LAY=layoutNow();
    LAY.forEach((t,i)=>drawTank(t[0]+CAGE_DX,t[1],t[2],i));
    // — РЕМЕНЬ временно СКРЫТ (v2): сначала ловим расположение и динамику баллонов —
    if(false){
      let minx=999,maxx=-999,topy=999,boty=-999;
      LAY.forEach(p=>{ minx=Math.min(minx,p[0]); maxx=Math.max(maxx,p[0]);
                       topy=Math.min(topy,p[1]); boty=Math.max(boty,p[1]); });
      const yb=bounce*0.5;                               // ремень чуть играет с грузом
      const x1=minx-10, x2=maxx+10, yT=topy-9+yb, yB=boty+9+yb;  // габариты обвязки
      const cxm=(x1+x2)/2, cym=(yT+yB)/2;                // центр пересключения
      ctx.lineCap='round';
      // тёмные ремни (две диагонали)
      ctx.strokeStyle='#2a1c12';ctx.lineWidth=3.0;
      ctx.beginPath();ctx.moveTo(x1,yB);ctx.lineTo(x2,yT);   // ╱
      ctx.moveTo(x1,yT);ctx.lineTo(x2,yB);ctx.stroke();      // ╲
      // блик
      ctx.strokeStyle='#43301c';ctx.lineWidth=1.1;
      ctx.beginPath();ctx.moveTo(x1,yB-1);ctx.lineTo(x2,yT-1);
      ctx.moveTo(x1,yT-1);ctx.lineTo(x2,yB-1);ctx.stroke();
      // пряжка в центре креста
      ctx.fillStyle='#5a4226';ctx.fillRect(cxm-3,cym-3,6,6);
      ctx.fillStyle='#3a2c18';ctx.fillRect(cxm-1.5,cym-1.5,3,3);
      ctx.lineCap='butt';
    }

    // — опоры вниз к раме/оси —
    ctx.strokeStyle=RUST.steelDk;ctx.lineWidth=3.2*CW();
    ctx.beginPath();
    ctx.moveTo(FB[0],FB[1]);ctx.lineTo(-30,-9);          // передняя опора → подрама (неподвижна)
    ctx.moveTo(RBs[0],RBs[1]);ctx.lineTo(RAXc.x,RAXc.y); // ЗАДНЯЯ стойка → ось колеса (с амортизацией)
    ctx.moveTo(RBs[0]+2,RBs[1]);ctx.lineTo(FB[0]-2,-12);ctx.stroke(); // косой раскос
    ctx.strokeStyle=RUST.steelLt;ctx.lineWidth=1.1;     // внутренний светлый блик опор
    ctx.beginPath();
    ctx.moveTo(FB[0],FB[1]-1);ctx.lineTo(-30,-10);
    ctx.moveTo(RBs[0],RBs[1]-1);ctx.lineTo(RAXc.x,RAXc.y-1);
    ctx.moveTo(RBs[0]+2,RBs[1]-1);ctx.lineTo(FB[0]-2,-13);ctx.stroke();
    // — нижний прут (длиннее на 12%) —
    ctx.strokeStyle=RUST.steel;ctx.lineWidth=3.2*CW();
    ctx.beginPath();ctx.moveTo(FB[0],FB[1]);ctx.lineTo(RBlong[0],RBlong[1]);ctx.stroke();
    // — контур: зад→FB→FT→вершина (передний скос FT→APEX НЕПОДВИЖЕН; зад просел) —
    ctx.beginPath();ctx.moveTo(RBs[0],RBs[1]);mv(FB);mv(FT);mv(APEX);ctx.stroke();
    ctx.strokeStyle=RUST.steelLt;ctx.lineWidth=1.1;     // внутренний светлый блик низа и контура
    ctx.beginPath();ctx.moveTo(FB[0],FB[1]-1);ctx.lineTo(RBlong[0],RBlong[1]-1);ctx.stroke();
    ctx.beginPath();ctx.moveTo(RBs[0],RBs[1]-1);ctx.lineTo(FB[0],FB[1]-1);ctx.moveTo(FB[0],FB[1]-1);ctx.lineTo(FT[0]+1,FT[1]);ctx.lineTo(APEX[0]+1,APEX[1]);ctx.stroke();
    // — БОЛТАЮЩАЯСЯ длинная грань: вершина APEX → задний конец RT —
    ctx.strokeStyle=RUST.steel;ctx.lineWidth=3.2*CW();
    ctx.beginPath();ctx.moveTo(HINGE[0],HINGE[1]);ctx.lineTo(RT[0],RT[1]);ctx.stroke();
    ctx.strokeStyle=RUST.steelLt;ctx.lineWidth=1.1;     // блик на грани и переднем скосе
    ctx.beginPath();ctx.moveTo(HINGE[0],HINGE[1]);ctx.lineTo(RT[0],RT[1]);ctx.moveTo(FT[0],FT[1]);mv(APEX);ctx.stroke();
    // — 1 горизонт. перегородка (вторую убрали — лучше видно баллоны); зад просел с осью —
    [{t:0.40, lift:1.0}].forEach(s=>{
      const a0=lerp(RBs,RTfixS,s.t), b=lerp(FB,FT,s.t);
      const a=[b[0]+(a0[0]-b[0])*1.20, b[1]+(a0[1]-b[1])*1.20];   // +20% длины вправо (назад)
      const wob = bar*s.lift;                             // подскок планки (свой ритм, не как баллоны)
      ctx.strokeStyle=RUST.steel;ctx.lineWidth=3.2*CW();
      ctx.beginPath();ctx.moveTo(a[0],a[1]+wob);ctx.lineTo(b[0],b[1]+wob*0.5);ctx.stroke();
      ctx.strokeStyle=RUST.steelLt;ctx.lineWidth=1.1;   // внутренний светлый блик перегородки
      ctx.beginPath();ctx.moveTo(a[0],a[1]+wob-1);ctx.lineTo(b[0],b[1]+wob*0.5-1);ctx.stroke();
    });
    ctx.lineCap='butt';ctx.lineJoin='miter';
    // — заклёпки по узлам; петля (вершина) выделена —
    ctx.fillStyle=RUST.engineDk;
    [FB,FT,RBs].forEach(([x,y])=>{ctx.beginPath();ctx.arc(x,y,1.5,0,7);ctx.fill();});
    ctx.fillStyle=RUST.steelLt;ctx.beginPath();ctx.arc(HINGE[0],HINGE[1],1.8,0,7);ctx.fill();
  }

  // ── ВИЛКА (длинная, раскатанная) + тройник + руль ──
  fork(head,FAX);
  ctx.fillStyle=RUST.engine;ctx.save();ctx.translate(head.x,head.y);ctx.rotate(0.5);
  ctx.fillRect(-6,-4,13,9);ctx.restore();                                          // тройник вдоль вилки
  ctx.strokeStyle=RUST.bar;ctx.lineWidth=3.2;ctx.lineCap='round';
  ctx.beginPath();ctx.moveTo(head.x,head.y-1);ctx.lineTo(head.x-10,head.y-12);ctx.stroke();   // руль
  ctx.beginPath();ctx.moveTo(head.x-10,head.y-12);ctx.lineTo(head.x-17,head.y-11);ctx.stroke(); // грип
  ctx.lineCap='butt';

  ctx.restore();
}
