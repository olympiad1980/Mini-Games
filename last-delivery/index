  ctx.fillStyle=NK;ctx.beginPath();
  ctx.moveTo(cBb.x,cBb.y);ctx.lineTo(cBt.x,cBt.y);ctx.lineTo(shB.x,shB.y);ctx.closePath();ctx.fill();
  // ближняя рука — ВРЕМЕННО скрыта
