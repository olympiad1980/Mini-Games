  ctx.fillStyle=RC.bootDk;ctx.beginPath();ctx.moveTo(-5,2.5);ctx.lineTo(12,2.5);ctx.lineTo(12,5);ctx.lineTo(-5,5);ctx.closePath();ctx.fill(); // подошва
