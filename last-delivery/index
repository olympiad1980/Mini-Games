  const neck=12, hL=lean*0.42+0.09;  // голова чуть вперёд (горб — за счёт круглой спины)
  const _ht=performance.now()/1000, _hsh=(P.shake||0);                       // тряска: голова болтается по инерции
  const _hbx=_hsh*Math.sin(_ht*34.0+0.5)*1.6, _hby=_hsh*Math.cos(_ht*45.0)*1.3;
  const hd={x:sh.x+Math.sin(hL)*neck+_hbx, y:sh.y-Math.cos(hL)*neck+_hby};
